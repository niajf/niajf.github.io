---
const { title, description } = Astro.props;
const SITE = "Taiga — Game Engineer Portfolio";
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description ?? "ゲームエンジニアを志望する学生のポートフォリオ"} />
    <title>{title ? `${title} | ${SITE}` : SITE}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Noto+Sans+JP:wght@400;500;700&family=JetBrains+Mono:wght@500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="bg-grid" aria-hidden="true"></div>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --bg: #0b0e14;
    --bg-soft: #111621;
    --card: #161c2b;
    --card-hover: #1b2336;
    --border: #232c40;
    --text: #e6e9f0;
    --text-dim: #9aa4b8;
    --accent: #7c8cff;
    --accent-2: #4fd1c5;
    --radius: 16px;
    --maxw: 1080px;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
  }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: "Inter", "Noto Sans JP", system-ui, sans-serif;
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
    position: relative;
    min-height: 100vh;
  }

  .bg-grid {
    position: fixed;
    inset: 0;
    z-index: -1;
    background:
      radial-gradient(60% 50% at 50% 0%, rgba(124, 140, 255, 0.12), transparent 70%),
      linear-gradient(var(--bg-soft) 1px, transparent 1px) 0 0 / 100% 64px,
      linear-gradient(90deg, var(--bg-soft) 1px, transparent 1px) 0 0 / 64px 100%;
    opacity: 0.5;
    mask-image: linear-gradient(to bottom, black, transparent 80%);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .container {
    max-width: var(--maxw);
    margin: 0 auto;
    padding: 0 24px;
  }

  .tag {
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    color: var(--accent-2);
    background: rgba(79, 209, 197, 0.08);
    border: 1px solid rgba(79, 209, 197, 0.2);
    padding: 3px 10px;
    border-radius: 999px;
    white-space: nowrap;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 600;
    font-size: 14px;
    padding: 10px 18px;
    border-radius: 10px;
    border: 1px solid var(--border);
    transition: all 0.18s ease;
  }
  .btn-primary {
    background: var(--accent);
    color: #0b0e14;
    border-color: var(--accent);
  }
  .btn-primary:hover {
    filter: brightness(1.1);
    transform: translateY(-1px);
  }
  .btn-ghost:hover {
    background: var(--card-hover);
    border-color: var(--accent);
  }
</style>
