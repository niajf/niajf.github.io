---
const { work } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const thumb = work.thumbnail ? base + work.thumbnail : null;
---

<a class="card" href={`${base}/works/${work.slug}/`}>
  <div class="thumb">
    {
      thumb ? (
        <img src={thumb} alt={work.title} loading="lazy" />
      ) : (
        <div class="thumb-placeholder">{work.title}</div>
      )
    }
    <span class="year">{work.year}</span>
  </div>
  <div class="body">
    <h3>{work.title}</h3>
    <p class="tagline">{work.tagline}</p>
    <div class="tags">
      {work.tags.slice(0, 4).map((t) => <span class="tag">{t}</span>)}
    </div>
  </div>
  <span class="arrow">→</span>
</a>

<style>
  .card {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .card:hover {
    transform: translateY(-4px);
    border-color: var(--accent);
    box-shadow: 0 16px 40px -16px rgba(124, 140, 255, 0.45);
  }
  .thumb {
    position: relative;
    aspect-ratio: 16 / 9;
    background: var(--bg-soft);
    overflow: hidden;
  }
  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }
  .card:hover .thumb img {
    transform: scale(1.04);
  }
  .thumb-placeholder {
    width: 100%;
    height: 100%;
    display: grid;
    place-items: center;
    color: var(--text-dim);
    font-weight: 700;
    font-size: 22px;
    letter-spacing: 0.04em;
    background: linear-gradient(135deg, #1a2030, #131826);
  }
  .year {
    position: absolute;
    top: 12px;
    right: 12px;
    font-family: "JetBrains Mono", monospace;
    font-size: 12px;
    color: var(--text-dim);
    background: rgba(11, 14, 20, 0.7);
    padding: 2px 8px;
    border-radius: 6px;
    backdrop-filter: blur(4px);
  }
  .body {
    padding: 18px 20px 22px;
  }
  h3 {
    font-size: 19px;
    font-weight: 700;
    margin-bottom: 4px;
  }
  .tagline {
    color: var(--text-dim);
    font-size: 14px;
    margin-bottom: 14px;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .arrow {
    position: absolute;
    bottom: 20px;
    right: 20px;
    color: var(--accent);
    font-size: 18px;
    opacity: 0;
    transform: translateX(-4px);
    transition: all 0.2s ease;
  }
  .card:hover .arrow {
    opacity: 1;
    transform: translateX(0);
  }
</style>
