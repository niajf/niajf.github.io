---
import Base from "../../layouts/Base.astro";
import works from "../../data/works.json";

export function getStaticPaths() {
  return works.map((work) => ({
    params: { slug: work.slug },
    props: { work },
  }));
}

const { work } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const thumb = work.thumbnail ? base + work.thumbnail : null;
---

<Base title={work.title} description={work.tagline}>
  <main class="container">
    <a class="back" href={`${base}/`}>← Works に戻る</a>

    <header class="head">
      <span class="yr">{work.year}</span>
      <h1>{work.title}</h1>
      <p class="tagline">{work.tagline}</p>
      <div class="tags">
        {work.tags.map((t) => <span class="tag">{t}</span>)}
      </div>
    </header>

    {
      thumb && (
        <div class="hero-img">
          <img src={thumb} alt={work.title} />
        </div>
      )
    }

    {
      work.video && (
        <div class="video">
          <iframe
            src={work.video}
            title={`${work.title} demo video`}
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          />
        </div>
      )
    }

    <section class="overview">
      <h2>概要</h2>
      <p>{work.description}</p>
    </section>

    <section class="overview">
      <h2>工夫したこと</h2>
      <ul class="highlights">
        {work.highlights.map((h) => <li>{h}</li>)}
      </ul>
    </section>

    <div class="actions">
      {
        work.repo && (
          <a class="btn btn-primary" href={work.repo} target="_blank" rel="noopener">
            GitHub リポジトリ
          </a>
        )
      }
      {
        work.demo && (
          <a class="btn btn-ghost" href={work.demo} target="_blank" rel="noopener">
            ブラウザでプレイ
          </a>
        )
      }
      {
        work.doc && (
          <a class="btn btn-ghost" href={import.meta.env.BASE_URL.replace(/\/$/, "") + work.doc} target="_blank" rel="noopener">
            企画書を見る
          </a>
        )
      }
    </div>
  </main>
</Base>

<style>
  main {
    padding: 48px 24px 100px;
    max-width: 820px;
  }
  .back {
    display: inline-block;
    color: var(--text-dim);
    font-size: 14px;
    margin-bottom: 40px;
    transition: color 0.15s ease;
  }
  .back:hover {
    color: var(--accent);
  }
  .yr {
    font-family: "JetBrains Mono", monospace;
    font-size: 13px;
    color: var(--accent);
  }
  h1 {
    font-size: clamp(34px, 6vw, 52px);
    font-weight: 700;
    line-height: 1.1;
    margin: 6px 0 10px;
  }
  .tagline {
    font-size: 17px;
    color: var(--text-dim);
    margin-bottom: 18px;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 40px;
  }
  .hero-img {
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    margin-bottom: 40px;
  }
  .hero-img img {
    width: 100%;
    display: block;
  }
  .video {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    margin-bottom: 40px;
  }
  .video iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .overview {
    margin-bottom: 36px;
  }
  h2 {
    font-size: 20px;
    font-weight: 700;
    margin-bottom: 12px;
    padding-left: 12px;
    border-left: 3px solid var(--accent);
  }
  .overview p {
    color: var(--text);
    font-size: 16px;
  }
  .highlights {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .highlights li {
    position: relative;
    padding-left: 24px;
    color: var(--text);
  }
  .highlights li::before {
    content: "▹";
    position: absolute;
    left: 0;
    color: var(--accent-2);
  }
  .actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }
</style>
